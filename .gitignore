# Python environment
.venv/

# Python generated files
__pycache__/
*.py[cod]
*$py.class

# Jupyter
.ipynb_checkpoints/

# Environment variables and secrets
.env
.env.*
!.env.example

# Documentation
docs/

#### Data files
# Ignore all data files by default.
data/**

# Allow Git to traverse the required data folders.
!data/
!data/processed/
!data/processed/metrics/
!data/processed/metrics/**/

# Track text metric files inside data/processed/metrics at any folder depth.
!data/processed/metrics/**/*.txt

#### Output files
# Ignore everything inside outputs by default.
outputs/**

# Allow Git to traverse outputs and its subfolders.
!outputs/
!outputs/**/

# Track Markdown reports inside outputs at any folder depth.
!outputs/**/*.md

# Keep outputs folder in Git even when no tracked files exist.
!outputs/.gitkeep

# Selected output files to track
!outputs/correlations/**/**/*.csv
!outputs/correlations/**/**/*.png

!outputs/linear_regression/**/**/*.csv

!outputs/linear_regression/ols_mc/COG_2feat_raw/figures/
!outputs/linear_regression/ols_mc/COG_2feat_raw/figures/*.png
!outputs/linear_regression/ols_mc/COG_3feat_raw/figures/
!outputs/linear_regression/ols_mc/COG_3feat_raw/figures/*.png
!outputs/linear_regression/ols_mc/MOT_2feat_raw/figures/
!outputs/linear_regression/ols_mc/MOT_2feat_raw/figures/*.png
!outputs/linear_regression/ols_mc/MOT_2feat_z/figures/
!outputs/linear_regression/ols_mc/MOT_2feat_z/figures/*.png

!outputs/linear_regression/ridgecv_mc/COG_2feat_raw/figures/
!outputs/linear_regression/ridgecv_mc/COG_2feat_raw/figures/*.png
!outputs/linear_regression/ridgecv_mc/COG_3feat_sch_raw_cov1/figures/
!outputs/linear_regression/ridgecv_mc/COG_3feat_sch_raw_cov1/figures/*.png
!outputs/linear_regression/ridgecv_mc/MOT_3feat_z/figures/
!outputs/linear_regression/ridgecv_mc/MOT_3feat_z/figures/*.png

# Track everything inside perm_test
!outputs/linear_regression/perm_test/**
!outputs/linear_regression/perm_test/**/**

# Operating system and editor files
.DS_Store
Thumbs.db
.vscode/
.idea/