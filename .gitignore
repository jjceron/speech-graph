# Python virtual environment
.venv/

# Project folders not to version
data/**
docs/

# Ignore everything inside outputs
outputs/**

# Track figures/ on folders within outputs, but ignore all other files
!outputs/
!outputs/**/
!outputs/01_run/figures/analysis/*.png
!outputs/01_run/figures/models/r2_heatmap_*.png
!outputs/01_run/figures/models/r2_best_by_target.png
!outputs/01_run/figures/interpretability/feature_relevance_by_schooling_*.png
!outputs/01_run/figures/interpretability/feature_relevance_population_*.png

!outputs/02_run/figures/analysis/top_partial_correlations_*.png
!outputs/02_run/figures/models/mc_best_mean_r2_by_target_model_set.png
!outputs/02_run/figures/models/mc_model_comparison_*.png
!outputs/02_run/figures/shap/shap_top_*_school_year_plus_nlp.png
!outputs/02_run/figures/shap/shap_top_*_nlp_only.png

# Allow Git to traverse the needed data folders
!data/
!data/processed/
!data/processed/metrics/
!data/processed/metrics/**/

# Track .txt files inside metrics at any depth
!data/processed/metrics/**/*.txt

# Track only Markdown files inside outputs, at any folder depth
!outputs/**/*.md

# Optional: keep the outputs folder in Git even if it has no tracked Markdown files
!outputs/.gitkeep

# Python cache files
__pycache__/
*.py[cod]
*$py.class

# Jupyter checkpoints
.ipynb_checkpoints/

# Environment variables / secrets
.env
.env.*
!.env.example

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/